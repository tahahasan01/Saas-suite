# ─── Database ─────────────────────────────────────────────
POSTGRES_USER=businessos
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=businessos
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Owner connection — migrations + auth/signup lookups (bypasses RLS as table owner)
DATABASE_URL=postgres://businessos:change_me_in_prod@localhost:5432/businessos
# Runtime connection — tenant-scoped queries as non-owner role (RLS enforced)
APP_DATABASE_URL=postgres://app_user:app_user_pw@localhost:5432/businessos

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ─── API ──────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
# Error tracking (optional; no-op if empty)
SENTRY_DSN=
ENABLE_SCHEDULER=true
# 32+ byte random string; used to sign session cookies
SESSION_SECRET=replace_with_openssl_rand_hex_32
NODE_ENV=development

# ─── Web ──────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Email ────────────────────────────────────────────────
# 'console' logs links in dev; 'smtp' sends for real (fill SMTP_* below).
EMAIL_PROVIDER=console
EMAIL_FROM=Business OS <no-reply@businessos.pk>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ─── AI (Phase 1) ─────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── WhatsApp Cloud API (Phase 1) ─────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# ─── Payments (Phase 1) ───────────────────────────────────
PAYMENT_PROVIDER=manual
SAFEPAY_API_KEY=
